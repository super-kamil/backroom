# ── API-Football (api-sports.io v3) ─────────────────────────────────────────
# Get a key at https://www.api-football.com/.
API_FOOTBALL_KEY=your_api_key_here

# API-Sports v3 host (default). Auth is the x-apisports-key header (api-client.ts).
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ── Run mode ────────────────────────────────────────────────────────────────
# live       = analyze an UPCOMING fixture (season-to-date stats baseline, last-N
#              form across all competitions, FRESH odds). REQUIRED for /analyze-match.
# validation = replay a COMPLETED season AS-OF each kickoff (no lookahead) for
#              backtesting / calibration (backtest.ts, /review-matchday).
# Code defaults to "validation" when unset — set MODE=live for live match analysis.
MODE=live

# Competition + season the VALIDATION/backtest path reads. Ignored by live mode,
# which uses each fixture's own league + season. In validation, point at a
# COMPLETED season your plan unlocks (the capability check, src/scripts/capability.ts,
# confirms access).
LEAGUE_ID=39   # 39 = Premier League
SEASON=2023    # 2023 = the completed 2023/24 season
# Recent-form window (matches), sliced client-side.
FORM_WINDOW=10

# ── Bankroll / staking discipline (Risk Manager) ────────────────────────────
# Total bankroll in your unit of account. Stakes are a fixed % of this.
BANKROLL=1000
# Fixed fraction of bankroll per bet (e.g. 0.02 = 2%). Hard discipline cap.
STAKE_PCT=0.02
# Absolute hard cap on any single stake, regardless of bankroll %.
MAX_STAKE=50

# ── Value rule (Trader) ─────────────────────────────────────────────────────
# Minimum edge (our prob − fair prob) required to call something "value".
# Accounts for estimation uncertainty; 0.05 = 5 percentage points.
VALUE_THRESHOLD=0.05

# ── De-vig method (math module) ─────────────────────────────────────────────
# proportional (MVP default, known-biased) | power | shin  (power/shin = extension)
DEVIG_METHOD=proportional
